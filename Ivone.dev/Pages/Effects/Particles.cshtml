@page "/effects/particles"
@model Ivone.dev.Pages.Effects.ParticlesModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>tsParticles — Effects</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { overflow: hidden; width: 100vw; height: 100vh; background: #0f172a; font-family: 'Space Grotesk', system-ui, sans-serif; }
        #tsparticles { position: fixed; inset: 0; z-index: 0; }

        .panel { position: fixed; top: 16px; right: 16px; width: 275px; max-height: calc(100vh - 32px); overflow-y: auto; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 14px; color: #f8fafc; z-index: 10; scrollbar-width: thin; scrollbar-color: rgba(124,58,237,0.4) transparent; }
        .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; cursor: pointer; user-select: none; }
        .panel-header h3 { margin: 0; font-size: 14px; font-weight: 600; }
        .toggle-btn { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 18px; line-height: 1; padding: 0 2px; }
        .panel.collapsed .panel-content { display: none; }

        .ctrl { margin-bottom: 10px; }
        .ctrl-label { display: flex; justify-content: space-between; font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: #64748b; margin-bottom: 4px; }
        .ctrl-label span { color: #a78bfa; font-weight: 600; }
        input[type="range"] { width: 100%; height: 3px; appearance: none; background: rgba(255,255,255,0.12); border-radius: 2px; outline: none; cursor: pointer; accent-color: #7c3aed; }
        input[type="range"]::-webkit-slider-thumb { appearance: none; width: 13px; height: 13px; border-radius: 50%; background: #7c3aed; cursor: pointer; border: 2px solid #c4b5fd; }
        select { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #f8fafc; padding: 7px 10px; font-family: inherit; font-size: 13px; cursor: pointer; outline: none; }
        select option, select optgroup { background: #0f172a; }

        .color-row { display: flex; gap: 5px; flex-wrap: wrap; }
        .color-chip { width: 22px; height: 22px; border-radius: 5px; cursor: pointer; border: 1px solid rgba(255,255,255,0.15); transition: transform 0.1s; flex-shrink: 0; }
        .color-chip:hover { transform: scale(1.25); }
        .color-chip.active { outline: 2px solid #c4b5fd; outline-offset: 2px; }

        .divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 10px 0; }

        .toggle-row { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 12px; color: #94a3b8; user-select: none; }
        .toggle-row input[type="checkbox"] { width: 14px; height: 14px; accent-color: #7c3aed; cursor: pointer; flex-shrink: 0; }

        .back-btn { position: fixed; top: 16px; left: 16px; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 10px; padding: 9px 16px; color: #f8fafc; text-decoration: none; font-size: 13px; font-weight: 500; z-index: 10; transition: border-color 0.15s, background 0.15s; }
        .back-btn:hover { border-color: rgba(124,58,237,0.5); background: rgba(124,58,237,0.2); }
        .label-tag { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 999px; padding: 8px 22px; color: #c4b5fd; font-size: 15px; font-weight: 600; z-index: 10; white-space: nowrap; }
        .hide-btn { position: fixed; bottom: 20px; right: 16px; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 10px; padding: 8px 14px; color: #64748b; font-family: inherit; font-size: 11px; cursor: pointer; z-index: 10; transition: color 0.15s; }
        .hide-btn:hover { color: #f8fafc; }
    </style>
</head>
<body>
<div id="tsparticles"></div>
<a href="/effects" class="back-btn">← Effects</a>
<div class="label-tag" id="label">Network</div>
<button class="hide-btn" id="hideBtn" onclick="toggleUI()">Hide UI</button>

<div class="panel" id="panel">
    <div class="panel-header" onclick="togglePanel()">
        <h3>tsParticles Controls</h3>
        <button class="toggle-btn" id="panelToggle">−</button>
    </div>
    <div class="panel-content">

        <div class="ctrl">
            <div class="ctrl-label">Preset</div>
            <select id="presetSel" onchange="loadPreset(this.value)">
                <optgroup label="Ambient">
                    <option value="network">Network / Links</option>
                    <option value="stars">Stars</option>
                    <option value="fireflies">Fireflies</option>
                    <option value="cosmicweb">Cosmic Web</option>
                    <option value="neon">Neon Glow</option>
                    <option value="breathing">Breathing Orbs</option>
                </optgroup>
                <optgroup label="Weather / Nature">
                    <option value="snow">Snow</option>
                    <option value="bubbles">Bubbles</option>
                    <option value="sandstorm">Sandstorm</option>
                    <option value="meteor">Meteor Shower</option>
                </optgroup>
                <optgroup label="Energetic">
                    <option value="confetti">Confetti</option>
                    <option value="fireworks">Fireworks</option>
                    <option value="matrix">Matrix Rain</option>
                    <option value="attract">Attract / Swarm</option>
                </optgroup>
            </select>
        </div>

        <hr class="divider">

        <div class="ctrl">
            <div class="ctrl-label">Count <span id="countVal">80</span></div>
            <input type="range" id="count" min="10" max="600" step="10" value="80" oninput="onCtrl('count','countVal',0)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Speed <span id="spdVal">2.0</span></div>
            <input type="range" id="spd" min="0.1" max="20" step="0.1" value="2.0" oninput="onCtrl('spd','spdVal',1)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Size <span id="szVal">3.0</span></div>
            <input type="range" id="sz" min="1" max="25" step="0.5" value="3.0" oninput="onCtrl('sz','szVal',1)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Opacity <span id="opVal">0.80</span></div>
            <input type="range" id="op" min="0.05" max="1" step="0.05" value="0.8" oninput="onCtrl('op','opVal',2)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Link Distance <span id="ldVal">150</span></div>
            <input type="range" id="ld" min="30" max="500" step="10" value="150" oninput="onCtrl('ld','ldVal',0)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Wobble / Spread <span id="wbVal">1.0</span></div>
            <input type="range" id="wb" min="0.1" max="5" step="0.1" value="1.0" oninput="onCtrl('wb','wbVal',1)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Rotate Speed <span id="rtVal">0</span></div>
            <input type="range" id="rt" min="0" max="60" step="1" value="0" oninput="onCtrl('rt','rtVal',0)">
        </div>
        <div class="ctrl">
            <div class="ctrl-label">Glow Radius <span id="glVal">0</span></div>
            <input type="range" id="gl" min="0" max="30" step="1" value="0" oninput="onCtrl('gl','glVal',0)">
        </div>

        <hr class="divider">

        <div class="ctrl">
            <div class="ctrl-label">Palette</div>
            <div class="color-row" id="paletteRow">
                <div class="color-chip active" style="background:#7c3aed" data-pal="purple" onclick="setPal('purple',this)"></div>
                <div class="color-chip" style="background:#ec4899" data-pal="pink" onclick="setPal('pink',this)"></div>
                <div class="color-chip" style="background:#06b6d4" data-pal="cyan" onclick="setPal('cyan',this)"></div>
                <div class="color-chip" style="background:#f97316" data-pal="orange" onclick="setPal('orange',this)"></div>
                <div class="color-chip" style="background:#22c55e" data-pal="green" onclick="setPal('green',this)"></div>
                <div class="color-chip" style="background:#f8fafc" data-pal="white" onclick="setPal('white',this)"></div>
                <div class="color-chip" style="background:#facc15" data-pal="gold" onclick="setPal('gold',this)"></div>
                <div class="color-chip" style="background:linear-gradient(135deg,#ec4899,#f97316,#facc15,#22c55e,#06b6d4,#7c3aed)" data-pal="rainbow" onclick="setPal('rainbow',this)"></div>
            </div>
        </div>

        <hr class="divider">

        <div class="ctrl">
            <label class="toggle-row">
                <input type="checkbox" id="mouseCtrl" onchange="loadPreset(currentPreset)">
                <span>Mouse interaction</span>
            </label>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tsparticles@2.12.0/tsparticles.bundle.min.js"></script>
<script>
const PALETTES = {
    purple:  ['#7c3aed','#a855f7','#c4b5fd','#4c1d95','#ddd6fe'],
    pink:    ['#ec4899','#f472b6','#fbcfe8','#9d174d','#fce7f3'],
    cyan:    ['#06b6d4','#22d3ee','#a5f3fc','#0e7490','#67e8f9'],
    orange:  ['#f97316','#fb923c','#fed7aa','#c2410c','#fdba74'],
    green:   ['#22c55e','#4ade80','#bbf7d0','#15803d','#86efac'],
    white:   ['#ffffff','#e2e8f0','#94a3b8','#cbd5e1','#f1f5f9'],
    gold:    ['#facc15','#fde047','#fef08a','#ca8a04','#fef9c3'],
    rainbow: ['#ec4899','#f97316','#facc15','#22c55e','#06b6d4','#7c3aed','#a855f7','#f43f5e'],
};
const PAL_BG = { purple:'#0a0418',pink:'#180410',cyan:'#010f17',orange:'#120800',green:'#011207',white:'#0f172a',gold:'#100e00',rainbow:'#080010' };

let activePal = 'purple';
let container = null;
let currentPreset = 'network';
let uiVisible = true;
let rebuildTimer = null;

const C = id => parseFloat(document.getElementById(id).value);
const CI = id => parseInt(document.getElementById(id).value);
const cols = () => PALETTES[activePal];
const bg   = () => PAL_BG[activePal];
const mouse = () => document.getElementById('mouseCtrl').checked;

function interactivity() {
    const on = mouse();
    return {
        detectsOn: 'canvas',
        events: {
            onHover: { enable: on, mode: 'grab' },
            onClick:  { enable: on, mode: 'push' },
            resize: true,
        },
        modes: { grab: { distance: CI('ld'), links: { opacity: 0.6 } }, push: { quantity: 4 } },
    };
}

function glowCfg() {
    const r = CI('gl');
    return r > 0 ? { enable: true, color: { value: cols() }, radius: r } : undefined;
}

function rotateCfg() {
    const s = CI('rt');
    return s > 0 ? { value: { min: 0, max: 360 }, direction: 'random', animation: { enable: true, speed: s } } : { value: 0 };
}

const PRESETS = {
    network: () => ({
        background: { color: { value: bg() } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            links: { color: { value: cols()[0] }, distance: C('ld'), enable: true, opacity: 0.3, width: 1 },
            move: { enable: true, speed: C('spd'), outModes: { default: 'bounce' } },
            number: { value: CI('count') },
            opacity: { value: C('op') },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.4, max: C('sz') } },
            rotate: rotateCfg(),
            glow: glowCfg(),
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    stars: () => ({
        background: { color: { value: '#030712' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            move: { enable: true, speed: C('spd') * 0.15, random: true, outModes: { default: 'out' } },
            number: { density: { enable: true, area: 600 }, value: CI('count') },
            opacity: { value: { min: 0.05, max: C('op') }, animation: { enable: true, speed: 0.6 * C('wb'), minimumValue: 0.05 } },
            shape: { type: ['circle','star'] },
            size: { value: { min: C('sz') * 0.3, max: C('sz') * 1.5 } },
            glow: glowCfg(),
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    fireflies: () => ({
        background: { color: { value: '#020b10' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            glow: { enable: true, color: { value: cols() }, radius: Math.max(CI('gl'), 15) },
            move: { enable: true, speed: C('spd') * 0.4, random: true, outModes: { default: 'bounce' }, type: 'random' },
            number: { density: { enable: true, area: 400 }, value: CI('count') },
            opacity: { value: { min: 0.05, max: C('op') }, animation: { enable: true, speed: C('wb') * 0.4, minimumValue: 0.05, sync: false } },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.4, max: C('sz') * 1.2 } },
            twinkle: { particles: { enable: true, frequency: 0.15, opacity: 1, color: { value: cols() } } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    cosmicweb: () => ({
        background: { color: { value: '#020408' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            links: { color: { value: cols()[0] }, distance: C('ld'), enable: true, opacity: 0.15, width: 0.5, triangles: { enable: true, opacity: 0.03 } },
            move: { enable: true, speed: C('spd') * 0.5, outModes: { default: 'bounce' }, random: true },
            number: { value: Math.min(CI('count') + 50, 400) },
            opacity: { value: { min: 0.2, max: C('op') } },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.3, max: C('sz') * 0.9 } },
            glow: glowCfg(),
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    neon: () => ({
        background: { color: { value: '#050810' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            glow: { enable: true, color: { value: cols() }, radius: Math.max(CI('gl'), 8) },
            links: { color: { value: cols() }, distance: C('ld') * 0.55, enable: true, opacity: 0.25, width: 1.2 },
            move: { enable: true, speed: C('spd'), outModes: { default: 'bounce' }, attract: { enable: true, rotateX: 600, rotateY: 1200 } },
            number: { density: { enable: true, area: 800 }, value: CI('count') },
            opacity: { value: C('op') },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.4, max: C('sz') * 1.5 } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    breathing: () => ({
        background: { color: { value: bg() } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            glow: glowCfg() || { enable: true, color: { value: cols() }, radius: 10 },
            move: { enable: true, speed: C('spd') * 0.3, outModes: { default: 'bounce' }, random: true },
            number: { value: CI('count') },
            opacity: { value: { min: 0.05, max: C('op') }, animation: { enable: true, speed: C('wb') * 1.5, minimumValue: 0.05, sync: true } },
            shape: { type: 'circle' },
            size: { value: { min: C('sz'), max: C('sz') * 4 }, animation: { enable: true, speed: C('wb') * 8, minimumValue: C('sz') * 0.3, sync: true } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    snow: () => ({
        background: { color: { value: bg() } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            move: { direction: 'bottom', enable: true, random: false, speed: C('spd'), straight: false, outModes: { default: 'out' } },
            number: { density: { enable: true, area: 800 }, value: CI('count') },
            opacity: { value: { min: 0.1, max: C('op') } },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.3, max: C('sz') } },
            wobble: { distance: 12 * C('wb'), enable: true, speed: C('spd') * 2 },
            rotate: rotateCfg(),
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    bubbles: () => ({
        background: { color: { value: '#030e18' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            move: { direction: 'top', enable: true, speed: C('spd'), outModes: { default: 'out' }, random: true },
            number: { density: { enable: true, area: 800 }, value: CI('count') },
            opacity: { value: { min: 0.05, max: C('op') * 0.5 }, animation: { enable: true, speed: 1 } },
            shape: { type: 'circle' },
            size: { value: { min: C('sz'), max: C('sz') * 5 } },
            stroke: { width: 1.5, color: { value: cols() } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    sandstorm: () => ({
        background: { color: { value: '#0a0700' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols().length > 1 ? [cols()[0], cols()[2] || cols()[0]] : cols() },
            move: { direction: 'right', enable: true, speed: C('spd') * 5, outModes: { default: 'out', right: 'out' }, random: true, straight: true },
            number: { density: { enable: true, area: 400 }, value: CI('count') },
            opacity: { value: { min: 0.1, max: C('op') } },
            shape: { type: 'circle' },
            size: { value: { min: 0.5, max: C('sz') * 0.7 } },
            wobble: { distance: 6 * C('wb'), enable: true, speed: C('spd') * 3 },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    meteor: () => ({
        background: { color: { value: '#030712' } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            move: { direction: 'bottom-right', enable: true, speed: C('spd') * 6, outModes: { default: 'out' }, random: false, straight: true },
            number: { density: { enable: true, area: 1200 }, value: CI('count') },
            opacity: { value: { min: 0.2, max: C('op') } },
            shape: { type: 'circle' },
            size: { value: { min: 0.5, max: C('sz') } },
            trail: { enable: true, length: 8 * C('wb'), fillColor: { value: '#030712' } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    confetti: () => ({
        background: { color: { value: bg() } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            move: { direction: 'bottom', enable: true, outModes: { default: 'out' }, speed: C('spd') * 2 },
            number: { density: { enable: true, area: 600 }, value: CI('count') },
            opacity: { value: C('op') },
            shape: { type: ['circle','square','triangle'] },
            size: { value: { min: C('sz') * 0.5, max: C('sz') * 2 } },
            rotate: { value: { min: 0, max: 360 }, direction: 'random', animation: { enable: true, speed: Math.max(CI('rt'), 20) } },
            tilt: { direction: 'random', enable: true, value: { min: 0, max: 360 }, animation: { enable: true, speed: 20 } },
            wobble: { distance: 10 * C('wb'), enable: true, speed: C('spd') * 2 },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    fireworks: () => ({
        background: { color: { value: '#020408' } },
        fpsLimit: 60,
        emitters: [{
            direction: 'top',
            life: { count: 0, duration: 0.1, delay: 0.25 },
            rate: { delay: 0.2, quantity: 1 },
            size: { width: 100, height: 0 },
            position: { y: 110, x: 50 },
        }],
        particles: {
            number: { value: 0 },
            destroy: {
                mode: 'split',
                split: {
                    count: 1,
                    particles: {
                        color: { value: cols() },
                        number: { value: 50 },
                        opacity: { value: { min: 0.2, max: 0.8 }, animation: { enable: true, speed: 0.6, minimumValue: 0, destroy: 'min' } },
                        size: { value: { min: 1, max: C('sz') } },
                        move: { enable: true, speed: { min: C('spd') * 2, max: C('spd') * 5 }, direction: 'outside', outModes: { default: 'destroy' } },
                    },
                },
            },
            life: { count: 1, duration: { sync: true, value: 0.8 } },
            move: { enable: true, gravity: { enable: false }, speed: C('spd') * 4, direction: 'top', outModes: { default: 'destroy', top: 'none' } },
            opacity: { value: 1 },
            shape: { type: 'circle' },
            size: { value: C('sz') * 0.4 },
            color: { value: cols() },
        },
        detectRetina: true,
    }),

    matrix: () => ({
        background: { color: { value: '#001100' } },
        fpsLimit: 60,
        particles: {
            color: { value: activePal === 'rainbow' ? cols() : [cols()[0], '#00ff41', '#00cc33'] },
            move: { direction: 'bottom', enable: true, speed: { min: C('spd'), max: C('spd') * 5 }, outModes: { default: 'out', bottom: 'out' }, random: true, straight: true },
            number: { density: { enable: true, area: 200 }, value: CI('count') },
            opacity: { value: { min: 0.1, max: C('op') } },
            shape: { type: 'circle' },
            size: { value: { min: 1, max: C('sz') * 0.8 } },
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),

    attract: () => ({
        background: { color: { value: bg() } },
        fpsLimit: 60,
        particles: {
            color: { value: cols() },
            glow: glowCfg(),
            links: { color: { value: cols()[0] }, distance: C('ld') * 0.5, enable: true, opacity: 0.2, width: 0.8 },
            move: { enable: true, speed: C('spd') * 1.5, outModes: { default: 'out' }, attract: { enable: true, rotate: { x: 600, y: 1200 } } },
            number: { density: { enable: true, area: 800 }, value: CI('count') },
            opacity: { value: C('op') },
            shape: { type: 'circle' },
            size: { value: { min: C('sz') * 0.3, max: C('sz') * 1.5 } },
            rotate: rotateCfg(),
        },
        interactivity: interactivity(),
        detectRetina: true,
    }),
};

const LABELS = { network:'Network / Links',stars:'Stars',fireflies:'Fireflies',cosmicweb:'Cosmic Web',neon:'Neon Glow',breathing:'Breathing Orbs',snow:'Snow',bubbles:'Bubbles',sandstorm:'Sandstorm',meteor:'Meteor Shower',confetti:'Confetti',fireworks:'Fireworks',matrix:'Matrix Rain',attract:'Attract / Swarm' };

async function loadPreset(name) {
    currentPreset = name;
    document.getElementById('label').textContent = LABELS[name] || name;
    if (container) { await container.destroy(); container = null; }
    try {
        container = await tsParticles.load('tsparticles', PRESETS[name]());
    } catch(e) { console.error('tsParticles error:', e); }
}

function onCtrl(id, val, decimals) {
    document.getElementById(id + 'Val') && (document.getElementById(id + 'Val').textContent = parseFloat(val).toFixed(decimals));
    clearTimeout(rebuildTimer);
    rebuildTimer = setTimeout(() => loadPreset(currentPreset), 250);
}

function setPal(name, el) {
    activePal = name;
    document.querySelectorAll('.color-chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    loadPreset(currentPreset);
}

function togglePanel() {
    const p = document.getElementById('panel');
    p.classList.toggle('collapsed');
    document.getElementById('panelToggle').textContent = p.classList.contains('collapsed') ? '+' : '−';
}

function toggleUI() {
    uiVisible = !uiVisible;
    ['panel','label'].forEach(id => document.getElementById(id).style.display = uiVisible ? '' : 'none');
    document.querySelector('.back-btn').style.display = uiVisible ? '' : 'none';
    const btn = document.getElementById('hideBtn');
    btn.style.display = '';
    btn.textContent = uiVisible ? 'Hide UI' : 'Show UI';
}

loadPreset('network');
</script>
</body>
</html>
