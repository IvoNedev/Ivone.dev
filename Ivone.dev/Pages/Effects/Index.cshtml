@page "/effects"
@model Ivone.dev.Pages.Effects.IndexModel
@{
    ViewData["Title"] = "Effects";
}

<section class="hero">
    <p class="eyebrow">Generative Art</p>
    <h1>Visual Effects</h1>
    <p class="lede">Procedurally generated backgrounds — record-ready for YouTube. Click any to explore with live controls.</p>
</section>

<div class="effects-grid">
    <a class="effect-card" href="/effects/vanta">
        <div class="preview preview-vanta">
            <div class="bird b1"></div>
            <div class="bird b2"></div>
            <div class="bird b3"></div>
            <div class="wave w1"></div>
            <div class="wave w2"></div>
        </div>
        <div class="card-body">
            <h2>Vanta.js</h2>
            <p>13 WebGL / three.js effects: birds, waves, fog, net, topology, rings, dots, halo, globe, cells, clouds, ripple, trunk</p>
            <ul class="tags">
                <li>Birds</li><li>Waves</li><li>Fog</li><li>Net</li><li>+9 more</li>
            </ul>
        </div>
    </a>

    <a class="effect-card" href="/effects/particles">
        <div class="preview preview-particles">
            <div class="dot d1"></div><div class="dot d2"></div><div class="dot d3"></div>
            <div class="dot d4"></div><div class="dot d5"></div><div class="dot d6"></div>
            <div class="dot d7"></div><div class="dot d8"></div>
        </div>
        <div class="card-body">
            <h2>tsParticles</h2>
            <p>8 particle presets with live sliders for count, speed, size, and color. Snowfall to fireworks.</p>
            <ul class="tags">
                <li>Snow</li><li>Confetti</li><li>Fireworks</li><li>Network</li><li>+4 more</li>
            </ul>
        </div>
    </a>

    <a class="effect-card" href="/effects/p5">
        <div class="preview preview-p5">
            <svg viewBox="0 0 200 120" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 80 Q25 40 50 60 T100 50 T150 70 T200 45" stroke="#7c3aed" stroke-width="2" fill="none" opacity="0.7"/>
                <path d="M0 90 Q30 50 60 70 T120 55 T180 75" stroke="#a855f7" stroke-width="1.5" fill="none" opacity="0.5"/>
                <path d="M0 70 Q20 30 50 50 T110 40 T160 65 T200 35" stroke="#c4b5fd" stroke-width="1" fill="none" opacity="0.4"/>
                <circle cx="45" cy="58" r="2" fill="#ec4899" opacity="0.8"/>
                <circle cx="95" cy="48" r="2" fill="#ec4899" opacity="0.8"/>
                <circle cx="145" cy="68" r="2" fill="#ec4899" opacity="0.8"/>
            </svg>
        </div>
        <div class="card-body">
            <h2>p5.js</h2>
            <p>5 creative-coding sketches: flow fields, Perlin waves, wandering lines, kaleidoscope, Lissajous.</p>
            <ul class="tags">
                <li>Flow Field</li><li>Perlin Waves</li><li>Kaleidoscope</li><li>+2 more</li>
            </ul>
        </div>
    </a>

    <a class="effect-card" href="/effects/shaders">
        <div class="preview preview-shaders">
            <div class="plasma-bg">
                <div class="plasma-circle pc1"></div>
                <div class="plasma-circle pc2"></div>
                <div class="plasma-circle pc3"></div>
            </div>
        </div>
        <div class="card-body">
            <h2>GLSL Shaders</h2>
            <p>9 raw WebGL fragment shaders: plasma, lava, aurora, holographic grid, tunnel, Voronoi, marble, fire, fractal.</p>
            <ul class="tags">
                <li>Plasma</li><li>Aurora</li><li>Lava</li><li>Fractal</li><li>+5 more</li>
            </ul>
        </div>
    </a>

    <a class="effect-card" href="/effects/three">
        <div class="preview preview-three">
            <div class="stars-bg">
                <div class="star s1"></div><div class="star s2"></div><div class="star s3"></div>
                <div class="star s4"></div><div class="star s5"></div><div class="star s6"></div>
                <div class="galaxy-arm ga1"></div>
                <div class="galaxy-arm ga2"></div>
            </div>
        </div>
        <div class="card-body">
            <h2>Three.js</h2>
            <p>5 hand-built 3D scenes: particle galaxy, wave grid, floating geometry, neural web, DNA helix.</p>
            <ul class="tags">
                <li>Galaxy</li><li>Wave Grid</li><li>Neural Web</li><li>+2 more</li>
            </ul>
        </div>
    </a>
</div>

@section Styles {
<style>
    .hero {
        padding: 2rem 1.5rem 1.5rem;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.35em;
        font-size: 0.7rem;
        color: rgba(248,250,252,0.5);
        margin: 0 0 0.5rem;
    }

    .hero h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(2rem, 5vw, 2.8rem);
        background: linear-gradient(100deg, #c4b5fd, #f0abfc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .lede {
        margin: 0;
        color: rgba(248,250,252,0.65);
        font-size: 0.95rem;
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .effects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
        padding: 0 0 1.5rem;
    }

    .effect-card {
        display: flex;
        flex-direction: column;
        background: rgba(15,23,42,0.85);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 18px;
        overflow: hidden;
        text-decoration: none;
        color: #f8fafc;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }

    .effect-card:hover {
        transform: translateY(-4px);
        border-color: rgba(124,58,237,0.4);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 0 1px rgba(124,58,237,0.2);
    }

    .preview {
        height: 140px;
        overflow: hidden;
        position: relative;
        background: #070d1e;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Vanta preview — animated birds + waves */
    .preview-vanta { background: linear-gradient(160deg, #060d1c, #0f1f3a); }
    .bird {
        position: absolute;
        width: 8px; height: 4px;
        background: #4f6ef7;
        border-radius: 50% 50% 0 0;
        animation: fly 4s ease-in-out infinite;
    }
    .b1 { top: 30%; left: 20%; animation-delay: 0s; }
    .b2 { top: 50%; left: 50%; animation-delay: 1.4s; }
    .b3 { top: 20%; left: 70%; animation-delay: 2.8s; }
    @@keyframes fly {
        0%,100% { transform: translateX(0) translateY(0) rotate(-5deg); }
        50% { transform: translateX(30px) translateY(-15px) rotate(5deg); }
    }
    .wave {
        position: absolute;
        left: -10%;
        width: 120%;
        height: 30px;
        border-radius: 50%;
        opacity: 0.25;
        animation: wave 3s ease-in-out infinite;
    }
    .w1 { top: 55%; background: #3b82f6; animation-delay: 0s; }
    .w2 { top: 70%; background: #6366f1; animation-delay: 1.5s; }
    @@keyframes wave {
        0%,100% { transform: scaleX(1) translateY(0); }
        50% { transform: scaleX(1.05) translateY(-6px); }
    }

    /* Particles preview */
    .preview-particles { background: linear-gradient(160deg, #050b1a, #0a1228); }
    .dot {
        position: absolute;
        border-radius: 50%;
        animation: float-dot 3s ease-in-out infinite;
    }
    .d1 { width:6px;height:6px;background:#7c3aed;top:20%;left:15%;animation-delay:0s; }
    .d2 { width:4px;height:4px;background:#ec4899;top:60%;left:30%;animation-delay:.4s; }
    .d3 { width:8px;height:8px;background:#06b6d4;top:40%;left:55%;animation-delay:.8s; }
    .d4 { width:3px;height:3px;background:#a3e635;top:75%;left:70%;animation-delay:1.2s; }
    .d5 { width:5px;height:5px;background:#f97316;top:25%;left:80%;animation-delay:.6s; }
    .d6 { width:4px;height:4px;background:#7c3aed;top:85%;left:20%;animation-delay:1.6s; }
    .d7 { width:6px;height:6px;background:#ec4899;top:10%;left:45%;animation-delay:2s; }
    .d8 { width:3px;height:3px;background:#06b6d4;top:55%;left:90%;animation-delay:2.4s; }
    @@keyframes float-dot {
        0%,100% { transform: translateY(0) scale(1); opacity: 0.8; }
        50% { transform: translateY(-12px) scale(1.2); opacity: 1; }
    }

    /* p5 preview — SVG waves */
    .preview-p5 { background: linear-gradient(160deg, #050b1a, #0a1228); }
    .preview-p5 svg { width: 100%; height: 100%; }

    /* Shaders preview */
    .preview-shaders { background: #0a0518; overflow: hidden; }
    .plasma-bg { position: absolute; inset: 0; }
    .plasma-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(30px);
        animation: pulse-blob 4s ease-in-out infinite;
    }
    .pc1 { width:100px;height:100px;background:rgba(167,51,255,0.6);top:20%;left:20%;animation-delay:0s; }
    .pc2 { width:80px;height:80px;background:rgba(236,72,153,0.6);top:50%;left:60%;animation-delay:1.5s; }
    .pc3 { width:120px;height:120px;background:rgba(59,130,246,0.5);top:-10%;left:50%;animation-delay:3s; }
    @@keyframes pulse-blob {
        0%,100% { transform: scale(1) translate(0,0); }
        50% { transform: scale(1.3) translate(10px,-10px); }
    }

    /* Three.js preview */
    .preview-three { background: #030712; }
    .stars-bg { position:absolute;inset:0; }
    .star {
        position:absolute;
        border-radius:50%;
        background:#fff;
        animation: twinkle 2s ease-in-out infinite;
    }
    .s1{width:2px;height:2px;top:15%;left:20%;animation-delay:0s;}
    .s2{width:1px;height:1px;top:35%;left:40%;animation-delay:.3s;}
    .s3{width:3px;height:3px;top:60%;left:65%;animation-delay:.7s;}
    .s4{width:1px;height:1px;top:25%;left:75%;animation-delay:1.1s;}
    .s5{width:2px;height:2px;top:70%;left:25%;animation-delay:1.5s;}
    .s6{width:1px;height:1px;top:45%;left:85%;animation-delay:1.9s;}
    @@keyframes twinkle {
        0%,100%{opacity:0.4;transform:scale(1);}
        50%{opacity:1;transform:scale(1.5);}
    }
    .galaxy-arm {
        position:absolute;
        width:140px;height:140px;
        border-radius:50%;
        top:50%;left:50%;
        margin:-70px 0 0 -70px;
        border:1px solid rgba(124,58,237,0.3);
        animation: spin 8s linear infinite;
    }
    .ga2 { width:80px;height:80px;margin:-40px 0 0 -40px;border-color:rgba(192,132,252,0.4);animation-duration:5s;animation-direction:reverse; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .card-body {
        padding: 1.25rem 1.25rem 1rem;
        flex: 1;
    }

    .card-body h2 {
        margin: 0 0 0.4rem;
        font-size: 1.15rem;
        font-weight: 600;
    }

    .card-body p {
        margin: 0 0 0.75rem;
        font-size: 0.82rem;
        color: rgba(248,250,252,0.6);
        line-height: 1.5;
    }

    .tags {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .tags li {
        font-size: 0.72rem;
        padding: 3px 9px;
        border-radius: 999px;
        background: rgba(124,58,237,0.18);
        border: 1px solid rgba(124,58,237,0.3);
        color: #c4b5fd;
    }
</style>
}
