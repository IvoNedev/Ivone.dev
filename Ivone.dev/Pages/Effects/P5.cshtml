@page "/effects/p5"
@model Ivone.dev.Pages.Effects.P5Model
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>p5.js — Effects</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { overflow: hidden; width: 100vw; height: 100vh; background: #030712; font-family: 'Space Grotesk', system-ui, sans-serif; }
        #p5canvas { position: fixed; inset: 0; z-index: 0; }
        #p5canvas canvas { display: block; }

        .panel { position: fixed; top: 16px; right: 16px; width: 270px; max-height: calc(100vh - 32px); overflow-y: auto; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 14px; color: #f8fafc; z-index: 10; scrollbar-width: thin; scrollbar-color: rgba(124,58,237,0.4) transparent; }
        .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; cursor: pointer; user-select: none; }
        .panel-header h3 { margin: 0; font-size: 14px; font-weight: 600; }
        .toggle-btn { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 18px; line-height: 1; padding: 0 2px; }
        .panel.collapsed .panel-content { display: none; }
        .ctrl { margin-bottom: 10px; }
        .ctrl-label { display: flex; justify-content: space-between; font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: #64748b; margin-bottom: 4px; }
        .ctrl-label span { color: #a78bfa; font-weight: 600; }
        input[type="range"] { width: 100%; height: 3px; appearance: none; background: rgba(255,255,255,0.12); border-radius: 2px; outline: none; cursor: pointer; accent-color: #7c3aed; }
        input[type="range"]::-webkit-slider-thumb { appearance: none; width: 13px; height: 13px; border-radius: 50%; background: #7c3aed; cursor: pointer; border: 2px solid #c4b5fd; }
        select { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; color: #f8fafc; padding: 7px 10px; font-family: inherit; font-size: 13px; cursor: pointer; outline: none; }
        select option { background: #0f172a; }
        .divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 10px 0; }
        .sketch-ctrl { display: none; }
        .sketch-ctrl.visible { display: block; }
        .back-btn { position: fixed; top: 16px; left: 16px; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 10px; padding: 9px 16px; color: #f8fafc; text-decoration: none; font-size: 13px; font-weight: 500; z-index: 10; transition: border-color 0.15s, background 0.15s; }
        .back-btn:hover { border-color: rgba(124,58,237,0.5); background: rgba(124,58,237,0.2); }
        .label-tag { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 999px; padding: 8px 22px; color: #c4b5fd; font-size: 15px; font-weight: 600; z-index: 10; white-space: nowrap; }
        .hide-btn { position: fixed; bottom: 20px; right: 16px; background: rgba(8,12,28,0.84); backdrop-filter: blur(18px); border: 1px solid rgba(255,255,255,0.09); border-radius: 10px; padding: 8px 14px; color: #64748b; font-family: inherit; font-size: 11px; cursor: pointer; z-index: 10; transition: color 0.15s; }
        .hide-btn:hover { color: #f8fafc; }
        .reset-btn { width: 100%; padding: 7px; background: rgba(124,58,237,0.2); border: 1px solid rgba(124,58,237,0.35); border-radius: 8px; color: #c4b5fd; font-family: inherit; font-size: 12px; cursor: pointer; transition: background 0.15s; margin-top: 4px; }
        .reset-btn:hover { background: rgba(124,58,237,0.35); }
    </style>
</head>
<body>
<div id="p5canvas"></div>
<a href="/effects" class="back-btn">← Effects</a>
<div class="label-tag" id="label">Flow Field</div>
<button class="hide-btn" id="hideBtn" onclick="toggleUI()">Hide UI</button>

<div class="panel" id="panel">
    <div class="panel-header" onclick="togglePanel()">
        <h3>p5.js Controls</h3>
        <button class="toggle-btn" id="panelToggle">−</button>
    </div>
    <div class="panel-content">
        <div class="ctrl">
            <div class="ctrl-label">Sketch</div>
            <select id="sketchSel" onchange="switchSketch(this.value)">
                <option value="flowfield">Flow Field</option>
                <option value="waves">Perlin Waves</option>
                <option value="wander">Wandering Lines</option>
                <option value="kaleid">Kaleidoscope</option>
                <option value="lissajous">Lissajous</option>
            </select>
        </div>
        <hr class="divider">
        <div class="ctrl">
            <div class="ctrl-label">Speed <span id="spdVal">1.0</span></div>
            <input type="range" id="spd" min="0.2" max="5" step="0.1" value="1.0" oninput="set('spd','spdVal',1)">
        </div>

        <!-- Flow Field controls -->
        <div class="sketch-ctrl visible" id="ctrl-flowfield">
            <div class="ctrl">
                <div class="ctrl-label">Particles <span id="ptVal">800</span></div>
                <input type="range" id="pt" min="100" max="3000" step="100" value="800" oninput="set('pt','ptVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Trail <span id="trailVal">4</span></div>
                <input type="range" id="trail" min="1" max="30" step="1" value="4" oninput="set('trail','trailVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Field Scale <span id="fsVal">20</span></div>
                <input type="range" id="fs" min="5" max="60" step="5" value="20" oninput="set('fs','fsVal',0)">
            </div>
        </div>

        <!-- Perlin Waves controls -->
        <div class="sketch-ctrl" id="ctrl-waves">
            <div class="ctrl">
                <div class="ctrl-label">Wave Count <span id="wcVal">8</span></div>
                <input type="range" id="wc" min="2" max="24" step="1" value="8" oninput="set('wc','wcVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Amplitude <span id="ampVal">120</span></div>
                <input type="range" id="amp" min="20" max="400" step="10" value="120" oninput="set('amp','ampVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Frequency <span id="freqVal">1.0</span></div>
                <input type="range" id="freq" min="0.3" max="5" step="0.1" value="1.0" oninput="set('freq','freqVal',1)">
            </div>
        </div>

        <!-- Wandering Lines controls -->
        <div class="sketch-ctrl" id="ctrl-wander">
            <div class="ctrl">
                <div class="ctrl-label">Lines <span id="lnVal">200</span></div>
                <input type="range" id="ln" min="20" max="800" step="20" value="200" oninput="set('ln','lnVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Wander <span id="wnVal">1.0</span></div>
                <input type="range" id="wn" min="0.1" max="4" step="0.1" value="1.0" oninput="set('wn','wnVal',1)">
            </div>
            <button class="reset-btn" onclick="resetCanvas()">Clear Canvas</button>
        </div>

        <!-- Kaleidoscope controls -->
        <div class="sketch-ctrl" id="ctrl-kaleid">
            <div class="ctrl">
                <div class="ctrl-label">Symmetry <span id="symVal">8</span></div>
                <input type="range" id="sym" min="3" max="24" step="1" value="8" oninput="set('sym','symVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Zoom <span id="kzVal">1.0</span></div>
                <input type="range" id="kz" min="0.3" max="2" step="0.1" value="1.0" oninput="set('kz','kzVal',1)">
            </div>
        </div>

        <!-- Lissajous controls -->
        <div class="sketch-ctrl" id="ctrl-lissajous">
            <div class="ctrl">
                <div class="ctrl-label">A <span id="laVal">3</span></div>
                <input type="range" id="la" min="1" max="9" step="1" value="3" oninput="set('la','laVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">B <span id="lbVal">2</span></div>
                <input type="range" id="lb" min="1" max="9" step="1" value="2" oninput="set('lb','lbVal',0)">
            </div>
            <div class="ctrl">
                <div class="ctrl-label">Delta <span id="ldVal">1.57</span></div>
                <input type="range" id="ldelta" min="0" max="6.28" step="0.01" value="1.5707" oninput="set('ldelta','ldVal',2)">
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/p5@1.9.0/lib/p5.min.js"></script>
<script>
let instance = null;
let currentSketch = 'flowfield';
let shouldReset = false;
let uiVisible = true;

function P(id) { return parseFloat(document.getElementById(id).value); }
function PI(id) { return parseInt(document.getElementById(id).value); }

function set(id, labelId, decimals) {
    const v = document.getElementById(id).value;
    document.getElementById(labelId).textContent = parseFloat(v).toFixed(decimals);
}

function g(id) { return document.getElementById(id).value; }

// ---- SKETCHES ----

function flowFieldSketch(p) {
    let particles = [], field = [], cols, rows, zoff = 0, bg;
    function makeParticles() {
        particles = [];
        const n = PI('pt');
        for (let i = 0; i < n; i++) particles.push({ x: p.random(p.width), y: p.random(p.height), px: 0, py: 0 });
    }
    p.setup = () => {
        const c = p.createCanvas(window.innerWidth, window.innerHeight);
        c.parent('p5canvas');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.background(230, 60, 5);
        bg = p.color(230, 60, 5);
        makeParticles();
    };
    p.draw = () => {
        const SCALE = PI('fs'), INC = 0.08, spd = P('spd');
        cols = Math.floor(p.width / SCALE) + 1;
        rows = Math.floor(p.height / SCALE) + 1;
        field = new Array(cols * rows);
        let yoff = 0;
        for (let y = 0; y < rows; y++) {
            let xoff = 0;
            for (let x = 0; x < cols; x++) {
                const a = p.noise(xoff, yoff, zoff) * p.TWO_PI * 4;
                field[x + y * cols] = [Math.cos(a), Math.sin(a)];
                xoff += INC;
            }
            yoff += INC;
        }
        zoff += 0.003 * spd;
        p.fill(230, 60, 5, P('trail'));
        p.noStroke();
        p.rect(0, 0, p.width, p.height);
        for (const pt of particles) {
            const cx = Math.floor(pt.x / SCALE), cy = Math.floor(pt.y / SCALE);
            const idx = cx + cy * cols;
            if (idx >= 0 && idx < field.length) {
                const [vx, vy] = field[idx];
                pt.px = pt.x; pt.py = pt.y;
                pt.x += vx * spd * 2;
                pt.y += vy * spd * 2;
            }
            const hue = (p.atan2(pt.y - pt.py, pt.x - pt.px) / p.TWO_PI * 360 + 360) % 360;
            p.stroke(hue, 85, 90, 85);
            p.strokeWeight(1);
            p.line(pt.px, pt.py, pt.x, pt.y);
            if (pt.x < 0 || pt.x > p.width || pt.y < 0 || pt.y > p.height) {
                pt.x = p.random(p.width); pt.y = p.random(p.height);
            }
        }
        if (particles.length !== PI('pt')) makeParticles();
    };
    p.windowResized = () => { p.resizeCanvas(window.innerWidth, window.innerHeight); p.background(230, 60, 5); makeParticles(); };
}

function wavesSketch(p) {
    p.setup = () => {
        const c = p.createCanvas(window.innerWidth, window.innerHeight);
        c.parent('p5canvas');
        p.colorMode(p.HSB, 360, 100, 100, 100);
    };
    p.draw = () => {
        p.background(230, 60, 5, 12);
        const wc = PI('wc'), amp = P('amp'), freq = P('freq'), spd = P('spd');
        const t = p.frameCount * 0.006 * spd;
        for (let w = 0; w < wc; w++) {
            const hue = (w / wc * 240 + t * 15) % 360;
            p.stroke(hue, 85, 92, 75);
            p.strokeWeight(1.5);
            p.noFill();
            p.beginShape();
            for (let x = 0; x <= p.width + 5; x += 4) {
                const n = p.noise(x * 0.003 * freq, w * 0.7, t);
                const base = p.map(w, 0, wc, p.height * 0.15, p.height * 0.85);
                const y = base + (n - 0.5) * amp * 2 + Math.sin(x * 0.02 * freq + w + t * 2) * amp * 0.3;
                p.vertex(x, y);
            }
            p.endShape();
        }
    };
    p.windowResized = () => p.resizeCanvas(window.innerWidth, window.innerHeight);
}

function wanderSketch(p) {
    let lines = [];
    function makeLines() {
        lines = [];
        for (let i = 0; i < PI('ln'); i++)
            lines.push({ x: p.random(p.width), y: p.random(p.height), a: p.random(p.TWO_PI), h: p.random(360) });
    }
    p.setup = () => {
        const c = p.createCanvas(window.innerWidth, window.innerHeight);
        c.parent('p5canvas');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.background(230, 60, 5);
        makeLines();
    };
    p.draw = () => {
        if (shouldReset) { p.background(230, 60, 5); shouldReset = false; }
        p.fill(230, 60, 5, 1.5);
        p.noStroke();
        p.rect(0, 0, p.width, p.height);
        const spd = P('spd') * 2, wn = P('wn');
        for (const l of lines) {
            l.a += p.random(-0.08, 0.08) * wn;
            const nx = l.x + Math.cos(l.a) * spd, ny = l.y + Math.sin(l.a) * spd;
            p.stroke(l.h, 80, 88, 65);
            p.strokeWeight(1);
            p.line(l.x, l.y, nx, ny);
            l.x = nx; l.y = ny;
            l.h = (l.h + 0.2) % 360;
            if (l.x < -10 || l.x > p.width+10 || l.y < -10 || l.y > p.height+10) {
                l.x = p.random(p.width); l.y = p.random(p.height);
            }
        }
        if (lines.length !== PI('ln')) makeLines();
    };
    p.windowResized = () => { p.resizeCanvas(window.innerWidth, window.innerHeight); p.background(230, 60, 5); makeLines(); };
}

function kaleidSketch(p) {
    p.setup = () => {
        const c = p.createCanvas(window.innerWidth, window.innerHeight);
        c.parent('p5canvas');
        p.colorMode(p.HSB, 360, 100, 100, 100);
    };
    p.draw = () => {
        p.background(230, 60, 5, 20);
        p.translate(p.width / 2, p.height / 2);
        const sym = PI('sym'), kz = P('kz'), spd = P('spd');
        const slice = p.TWO_PI / sym;
        const t = p.frameCount * 0.008 * spd;
        const R = Math.min(p.width, p.height) * 0.5 * kz;
        for (let s = 0; s < sym; s++) {
            p.push();
            p.rotate(s * slice);
            drawSlice(p, t, R);
            p.scale(1, -1);
            drawSlice(p, t, R);
            p.pop();
        }
    };
    function drawSlice(p, t, R) {
        p.strokeWeight(1.5);
        for (let r = 0; r < R; r += 6) {
            const n = p.noise(r * 0.015, t + r * 0.003);
            const a = n * p.TWO_PI * 2;
            const x = r * Math.cos(a), y = r * Math.sin(a * 0.6);
            const hue = (r * 0.7 + t * 40) % 360;
            p.stroke(hue, 82, 90, 60);
            p.point(x, y);
        }
    }
    p.windowResized = () => p.resizeCanvas(window.innerWidth, window.innerHeight);
}

function lissajousSketch(p) {
    let hueOff = 0;
    p.setup = () => {
        const c = p.createCanvas(window.innerWidth, window.innerHeight);
        c.parent('p5canvas');
        p.colorMode(p.HSB, 360, 100, 100, 100);
    };
    p.draw = () => {
        p.background(230, 60, 5, 8);
        p.translate(p.width / 2, p.height / 2);
        const a = PI('la'), b = PI('lb'), delta = P('ldelta'), spd = P('spd');
        const R = Math.min(p.width, p.height) * 0.42;
        const t = p.frameCount * 0.004 * spd;
        p.noFill();
        p.strokeWeight(1.5);
        p.beginShape();
        const STEPS = 800;
        for (let i = 0; i <= STEPS; i++) {
            const ang = (i / STEPS) * p.TWO_PI * p.lcm(a, b);
            const x = R * Math.sin(a * ang + delta + t);
            const y = R * Math.sin(b * ang + t * 0.7);
            const hue = (hueOff + i / STEPS * 360) % 360;
            p.stroke(hue, 85, 92, 80);
            p.vertex(x, y);
        }
        p.endShape();
        hueOff = (hueOff + 0.3 * spd) % 360;
    };
    p.lcm = (a, b) => { let x = a, y = b; while (y) { [x, y] = [y, x % y]; } return a * b / x; };
    p.windowResized = () => p.resizeCanvas(window.innerWidth, window.innerHeight);
}

// ---- Routing ----

const SKETCHES = { flowfield: flowFieldSketch, waves: wavesSketch, wander: wanderSketch, kaleid: kaleidSketch, lissajous: lissajousSketch };
const LABELS = { flowfield: 'Flow Field', waves: 'Perlin Waves', wander: 'Wandering Lines', kaleid: 'Kaleidoscope', lissajous: 'Lissajous' };

function switchSketch(name) {
    currentSketch = name;
    document.getElementById('label').textContent = LABELS[name];
    document.querySelectorAll('.sketch-ctrl').forEach(el => el.classList.remove('visible'));
    const ctrl = document.getElementById('ctrl-' + name);
    if (ctrl) ctrl.classList.add('visible');
    if (instance) { instance.remove(); instance = null; }
    document.getElementById('p5canvas').innerHTML = '';
    instance = new p5(SKETCHES[name]);
}

function resetCanvas() { shouldReset = true; }

function togglePanel() {
    const p = document.getElementById('panel');
    p.classList.toggle('collapsed');
    document.getElementById('panelToggle').textContent = p.classList.contains('collapsed') ? '+' : '−';
}

function toggleUI() {
    uiVisible = !uiVisible;
    ['panel','label'].forEach(id => document.getElementById(id).style.display = uiVisible ? '' : 'none');
    document.querySelector('.back-btn').style.display = uiVisible ? '' : 'none';
    const btn = document.getElementById('hideBtn');
    btn.style.display = '';
    btn.textContent = uiVisible ? 'Hide UI' : 'Show UI';
}

switchSketch('flowfield');
</script>
</body>
</html>
