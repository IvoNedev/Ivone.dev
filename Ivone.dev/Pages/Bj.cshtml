                    <label>L4 strong <input id="bj-count-quiz-strong-l4" type="number" min="0.1" step="0.1" value="12.0" /></label>
                    <label>L5 acceptable <input id="bj-count-quiz-target-l5" type="number" min="0.1" step="0.1" value="20.0" /></label>
                    <label>L5 strong <input id="bj-count-quiz-strong-l5" type="number" min="0.1" step="0.1" value="15.0" /></label>
                </div>

                <h3 class="bj-subheading">Speed Count Targets (seconds)</h3>
                <div class="bj-grid bj-target-grid">
                    <label>L1 acceptable <input id="bj-speed-target-l1" type="number" min="0.1" step="0.1" value="4.0" /></label>
                    <label>L2 acceptable <input id="bj-speed-target-l2" type="number" min="0.1" step="0.1" value="7.0" /></label>
                    <label>L3 acceptable <input id="bj-speed-target-l3" type="number" min="0.1" step="0.1" value="30.0" /></label>
                    <label>L3 strong <input id="bj-speed-strong-l3" type="number" min="0.1" step="0.1" value="22.0" /></label>
                    <label>L4 acceptable <input id="bj-speed-target-l4" type="number" min="0.1" step="0.1" value="22.0" /></label>
                    <label>L4 strong <input id="bj-speed-strong-l4" type="number" min="0.1" step="0.1" value="20.0" /></label>
                    <label>L5 acceptable <input id="bj-speed-target-l5" type="number" min="0.1" step="0.1" value="18.0" /></label>
                    <label>L5 strong <input id="bj-speed-strong-l5" type="number" min="0.1" step="0.1" value="15.0" /></label>
                </div>
                <p class="bj-mono">Readiness rule: 5 perfect runs in a row, repeated on 2 separate days.</p>
            </div>
        </details>
    </section>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&family=Rajdhani:wght@600;700&display=swap');

    :root {
        color-scheme: dark;
        --bj-page-bg: #060708;
        --bj-bg: #0b0d10;
        --bj-panel: #111419;
        --bj-panel-2: #171b22;
        --bj-panel-3: #0d1015;
        --bj-border: rgba(255,255,255,0.1);
        --bj-border-strong: rgba(255,255,255,0.18);
        --bj-text: #f4f4f5;
        --bj-text-soft: #aeb4bf;
        --bj-text-dim: #69717f;
        --bj-field-bg: #090b0f;
        --bj-field-border: rgba(255,255,255,0.16);
        --bj-accent-red: #c41222;
        --bj-accent-red-dark: #6f0710;
        --bj-red-glow: rgba(220, 20, 45, 0.42);
        --bj-gold: #d5a84f;
        --bj-gold-muted: #8d6a2e;
        --bj-success: #18b56b;
        --bj-warning: #e6a93a;
        --bj-danger: #e43f4f;
        --bj-felt-dark: #032015;
        --bj-felt-mid: #06462b;
        --bj-felt-light: #0b7a45;
        --bj-rail-black: #080808;
        --bj-rail-brown: #2a160d;
        --bj-card-bg: #f6f2e9;
        --bj-card-text: #16191f;
        --bj-card-border: rgba(0,0,0,0.3);
        --bj-disabled-bg: #252933;
        --bj-disabled-text: #676f7d;
        --bj-focus-glow: rgba(196,18,34,0.28);
        --bj-radius-sm: 8px;
        --bj-radius-md: 12px;
        --bj-shadow-panel: 0 18px 48px rgba(0,0,0,0.42), inset 0 1px 0 rgba(255,255,255,0.05);
        --bj-shadow-hard: 0 28px 80px rgba(0,0,0,0.65);
    }

    :root[data-bj-theme="light"] {
        color-scheme: light;
        --bj-page-bg: #111318;
        --bj-bg: #0d0f13;
        --bj-panel: #151921;
        --bj-panel-2: #1b2029;
        --bj-panel-3: #11151b;
        --bj-text: #f8fafc;
        --bj-text-soft: #c4cad4;
        --bj-text-dim: #7e8795;
        --bj-field-bg: #0c0f14;
        --bj-field-border: rgba(255,255,255,0.18);
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        background:
            radial-gradient(circle at 50% 0%, rgba(196, 18, 34, 0.2), transparent 34%),
            radial-gradient(circle at 82% 64%, rgba(11, 122, 69, 0.13), transparent 30%),
            linear-gradient(180deg, #101116 0%, var(--bj-page-bg) 100%) !important;
        color: var(--bj-text) !important;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    }

    .container,
    .container-fluid {
        max-width: none !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    .app-shell {
        padding: 0 !important;
        gap: 0 !important;
        background: transparent !important;
    }

    .app-main {
        padding: 0 !important;
        border-radius: 0 !important;
        background: transparent !important;
    }

    .bj-layout {
        min-height: 100dvh;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        grid-template-areas:
            "topbar"
            "stage"
            "hud"
            "sidebar"
            "bottom"
            "study";
        gap: 12px;
        padding: 12px;
        color: var(--bj-text);
        font-size: 14px;
        overflow-x: hidden;
    }

    .bj-topbar {
        grid-area: topbar;
        min-height: 64px;
        display: grid;
        gap: 12px;
        align-items: center;
        padding: 12px;
        border-bottom: 1px solid rgba(196,18,34,0.45);
        background:
            linear-gradient(180deg, rgba(255,255,255,0.055), rgba(255,255,255,0.015)),
            repeating-linear-gradient(135deg, rgba(255,255,255,0.025) 0 1px, transparent 1px 6px),
            #0b0d10;
        box-shadow: 0 12px 36px rgba(0,0,0,0.38);
    }

    .bj-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .bj-brand-mark {
        width: 42px;
        height: 42px;
        flex: 0 0 auto;
        border-radius: 50%;
        background:
            linear-gradient(135deg, rgba(213,168,79,0.95), rgba(111,7,16,0.95)),
            radial-gradient(circle at 50% 42%, rgba(255,255,255,0.35), transparent 38%);
        border: 1px solid rgba(255,255,255,0.18);
        box-shadow: 0 0 30px rgba(196,18,34,0.3), inset 0 2px 0 rgba(255,255,255,0.22);
        position: relative;
    }

    .bj-brand-mark::before,
    .bj-brand-mark::after {
        content: "";
        position: absolute;
        inset: 11px;
        border: 2px solid rgba(8,8,8,0.74);
        transform: rotate(45deg);
    }

    .bj-brand h1 {
        margin: 0;
        font-family: Rajdhani, Inter, sans-serif;
        font-size: clamp(1.35rem, 2vw, 1.9rem);
        line-height: 0.95;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .bj-kicker,
    .bj-mode-chip span,
    .bj-top-metric span,
    .bj-subheading,
    .bj-collapsible > summary,
    .bj-stats-grid span,
    .bj-speed-stats span,
    .bj-count-quiz-stats span {
        display: block;
        color: var(--bj-text-soft);
        font-size: 11px;
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
    }

    .bj-topbar-center,
    .bj-topbar-metrics {
        display: grid;
        gap: 8px;
    }

    .bj-topbar-center {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bj-topbar-metrics {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .bj-mode-chip,
    .bj-top-metric {
        min-width: 0;
        padding: 10px 12px;
        border-radius: var(--bj-radius-sm);
        background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.015)), var(--bj-panel);
        border: 1px solid var(--bj-border);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .bj-mode-chip strong,
    .bj-top-metric strong {
        display: block;
        margin-top: 4px;
        overflow-wrap: anywhere;
        color: var(--bj-text);
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 13px;
        font-weight: 700;
    }

    .bj-sidebar,
    .bj-stage,
    .bj-hud,
    .bj-bottom-strip,
    .bj-study-panels {
        min-width: 0;
    }

    .bj-sidebar {
        grid-area: sidebar;
        display: grid;
        gap: 12px;
        align-content: start;
    }

    .bj-sidebar-head {
        display: none;
    }

    .bj-nav-list {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: minmax(148px, 1fr);
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 2px;
    }

    .bj-nav-item {
        min-height: 52px;
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr) auto;
        align-items: center;
        gap: 9px;
        padding: 9px;
        border-radius: var(--bj-radius-sm);
        border: 1px solid var(--bj-border);
        color: var(--bj-text-soft);
        text-decoration: none;
        background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01)), var(--bj-panel);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        transition: transform 160ms ease, border-color 160ms ease, color 160ms ease, box-shadow 160ms ease;
    }

    .bj-nav-item:hover {
        transform: translateY(-1px);
        color: #fff;
        border-color: rgba(213,168,79,0.38);
    }

    .bj-nav-item.active {
        color: #fff;
        background: linear-gradient(90deg, rgba(196,18,34,0.95), rgba(111,7,16,0.68));
        border-color: rgba(255,255,255,0.16);
        box-shadow: inset 3px 0 0 #ff4054, 0 0 24px rgba(196,18,34,0.25);
    }

    .bj-nav-item span:not(.bj-nav-icon) {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 700;
    }

    .bj-nav-item em {
        font-style: normal;
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        color: rgba(255,255,255,0.68);
    }

    .bj-nav-icon {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.16);
        background:
            radial-gradient(circle at 50% 50%, rgba(213,168,79,0.28), transparent 52%),
            #0a0c10;
        position: relative;
    }

    .bj-nav-icon::before,
    .bj-nav-icon::after {
        content: "";
        position: absolute;
        border-radius: 2px;
        background: currentColor;
        opacity: 0.78;
    }

    .bj-nav-icon.cards::before { width: 11px; height: 15px; left: 8px; top: 6px; transform: rotate(-9deg); background: transparent; border: 2px solid currentColor; }
    .bj-nav-icon.chart::before { width: 3px; height: 12px; left: 7px; top: 10px; box-shadow: 6px -5px 0 currentColor, 12px -2px 0 currentColor; }
    .bj-nav-icon.target::before { inset: 7px; background: transparent; border: 2px solid currentColor; border-radius: 50%; }
    .bj-nav-icon.speed::before { width: 14px; height: 8px; left: 7px; top: 9px; background: transparent; border: 2px solid currentColor; border-bottom: 0; border-radius: 14px 14px 0 0; }
    .bj-nav-icon.deviation::before { width: 14px; height: 2px; left: 7px; top: 13px; transform: rotate(-28deg); }
    .bj-nav-icon.replay::before { width: 13px; height: 13px; left: 7px; top: 7px; background: transparent; border: 2px solid currentColor; border-right-color: transparent; border-radius: 50%; }
    .bj-nav-icon.rules::before { width: 14px; height: 10px; left: 7px; top: 9px; background: transparent; border: 2px solid currentColor; }
    .bj-nav-icon.settings::before { width: 14px; height: 14px; left: 7px; top: 7px; background: transparent; border: 2px solid currentColor; border-radius: 50%; }

    .bj-stage {
        grid-area: stage;
    }

    .bj-table {
        display: grid;
        gap: 12px;
    }

    .bj-game-focus {
        position: relative;
        padding: clamp(18px, 2vw, 28px);
        border-radius: 28px;
        background:
            radial-gradient(circle at 50% 0%, rgba(196,18,34,0.16), transparent 42%),
            linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01)),
            #050607;
        box-shadow: var(--bj-shadow-hard);
        overflow: visible;
    }

    .bj-table-felt {
        position: relative;
        width: min(100%, 1100px);
        min-height: clamp(430px, 46vw, 610px);
        margin: 0 auto;
        border-radius: 48% 48% 40% 40% / 42% 42% 30% 30%;
        background:
            radial-gradient(circle at 50% 36%, rgba(70,180,100,0.28), transparent 43%),
            radial-gradient(circle at 50% 92%, rgba(0,0,0,0.48), transparent 42%),
            linear-gradient(145deg, var(--bj-felt-mid) 0%, #05381f 48%, var(--bj-felt-dark) 100%);
        border: clamp(10px, 1.5vw, 16px) solid #101010;
        box-shadow:
            inset 0 0 100px rgba(0,0,0,0.6),
            inset 0 0 10px rgba(255,255,255,0.08),
            0 24px 70px rgba(0,0,0,0.7);
        isolation: isolate;
        overflow: hidden;
    }

    .bj-table-felt::before {
        content: "";
        position: absolute;
        inset: -24px;
        border-radius: inherit;
        background: linear-gradient(145deg, var(--bj-rail-brown), #090909 45%, #24120c);
        z-index: -1;
        box-shadow: inset 0 2px 6px rgba(255,255,255,0.08), 0 20px 60px rgba(0,0,0,0.8);
    }

    .bj-felt-noise {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.52;
        background-image:
            radial-gradient(circle at 20% 10%, rgba(255,255,255,0.055), transparent 18%),
            radial-gradient(circle at 80% 80%, rgba(0,0,0,0.22), transparent 26%),
            repeating-linear-gradient(0deg, rgba(255,255,255,0.018) 0 1px, transparent 1px 3px),
            repeating-linear-gradient(90deg, rgba(0,0,0,0.035) 0 1px, transparent 1px 4px);
        mix-blend-mode: overlay;
    }

    .bj-table-rule {
        position: absolute;
        z-index: 1;
        color: rgba(218,255,222,0.16);
        font-family: Rajdhani, Inter, sans-serif;
        font-size: clamp(12px, 1.3vw, 18px);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        text-shadow: 0 1px 2px rgba(0,0,0,0.6);
        pointer-events: none;
        white-space: nowrap;
    }

    .bj-table-rule-top { top: 19%; left: 50%; transform: translateX(-50%); }
    .bj-table-rule-left { top: 44%; left: 7%; transform: rotate(-72deg); transform-origin: left center; }
    .bj-table-rule-bottom { bottom: 15%; left: 50%; transform: translateX(-50%); }

    .bj-dealer-zone,
    .bj-player-zone {
        position: absolute;
        z-index: 3;
        left: 50%;
        transform: translateX(-50%);
        display: grid;
        justify-items: center;
        gap: 12px;
        width: min(86%, 720px);
    }

    .bj-dealer-zone { top: 7%; }
    .bj-player-zone { bottom: 8%; }

    .bj-dealer-plate,
    .bj-player-heading {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 34px;
        padding: 7px 13px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02)), rgba(4,5,7,0.72);
        border: 1px solid rgba(255,255,255,0.13);
        box-shadow: 0 10px 24px rgba(0,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.08);
    }

    .bj-dealer-plate span,
    .bj-player-heading span {
        color: var(--bj-text-soft);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-weight: 800;
    }

    .bj-dealer-plate strong,
    .bj-player-heading strong {
        color: #fff;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
    }

    .bj-lobby-win { color: var(--bj-success) !important; }
    .bj-lobby-loss { color: var(--bj-danger) !important; }

    .bj-cards {
        display: flex;
        gap: clamp(7px, 1vw, 12px);
        flex-wrap: wrap;
        justify-content: center;
        min-height: clamp(78px, 12vw, 118px);
    }

    .bj-card {
        width: clamp(56px, 7vw, 92px);
        aspect-ratio: 5 / 7;
        display: grid;
        place-items: center;
        border-radius: 10px;
        background:
            radial-gradient(circle at 32% 26%, rgba(255,255,255,0.78), transparent 28%),
            linear-gradient(160deg, #fff, #e9e5dd);
        color: var(--bj-card-text);
        border: 1px solid var(--bj-card-border);
        box-shadow: 0 10px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.9);
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(1.1rem, 2.1vw, 1.8rem);
        font-weight: 800;
        line-height: 1;
        position: relative;
        transform: rotate(var(--card-tilt, -1deg));
        animation: bj-card-deal 220ms ease-out both;
    }

    .bj-card:nth-child(even) { --card-tilt: 1.4deg; }
    .bj-card-corner {
        position: absolute;
        display: grid;
        justify-items: center;
        gap: 1px;
        font-size: clamp(0.62rem, 1vw, 0.82rem);
        line-height: 1;
    }

    .bj-card-corner-top {
        top: 7px;
        left: 7px;
    }

    .bj-card-corner-bottom {
        right: 7px;
        bottom: 7px;
        transform: rotate(180deg);
    }

    .bj-card-center {
        font-size: clamp(1.22rem, 2.35vw, 2.05rem);
    }

    .bj-card.hidden {
        background:
            linear-gradient(135deg, #8b1018, #3b0509),
            repeating-linear-gradient(45deg, rgba(255,255,255,0.05) 0 2px, transparent 2px 8px);
        color: rgba(255,230,190,0.92);
        border: 2px solid rgba(255,210,120,0.45);
    }

    .bj-card.hidden::before {
        content: "BJ";
        display: grid;
        place-items: center;
        width: 62%;
        aspect-ratio: 1;
        border: 1px solid rgba(255,210,120,0.35);
        transform: rotate(45deg);
        color: rgba(255,230,190,0.88);
        font-size: 0.8rem;
    }

    .bj-card.hidden > * { display: none; }
    .bj-suit-red { color: #c41222; }

    .bj-hand-stack {
        display: grid;
        gap: 10px;
        width: min(100%, 720px);
    }

    .bj-hand {
        display: grid;
        justify-items: center;
        gap: 9px;
        padding: 10px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(2,10,7,0.32);
        box-shadow: inset 0 0 30px rgba(0,0,0,0.2);
    }

    .bj-hand.active {
        border-color: rgba(24,181,107,0.78);
        box-shadow: 0 0 26px rgba(24,181,107,0.18), inset 0 0 30px rgba(0,0,0,0.2);
    }

    .bj-hand-meta {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
        color: rgba(244,244,245,0.88);
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        font-weight: 700;
    }

    .bj-tray {
        position: absolute;
        z-index: 2;
        display: grid;
        gap: 5px;
        justify-items: center;
        color: rgba(255,255,255,0.58);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-weight: 800;
    }

    .bj-shoe-tray { top: 25%; right: 8%; }
    .bj-discard-tray { top: 25%; left: 8%; }
    .bj-tray i {
        display: block;
        width: 44px;
        height: 28px;
        border-radius: 5px;
        background: linear-gradient(135deg, #15191f, #050608);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 8px 18px rgba(0,0,0,0.4);
    }

    .bj-center-mark {
        position: absolute;
        z-index: 1;
        inset: 39% 32% auto;
        min-height: 64px;
        border: 2px solid rgba(213,168,79,0.2);
        border-radius: 999px;
        display: grid;
        place-items: center;
        color: rgba(255,230,170,0.18);
        font-family: Rajdhani, Inter, sans-serif;
        font-size: clamp(13px, 1.6vw, 20px);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 700;
    }

    .bj-bet-circle {
        position: absolute;
        z-index: 3;
        left: 18%;
        bottom: 18%;
        width: clamp(88px, 12vw, 132px);
        aspect-ratio: 1;
        border: 2px solid rgba(255,215,130,0.32);
        box-shadow: inset 0 0 18px rgba(255,200,80,0.08), 0 0 24px rgba(255,190,80,0.08);
        border-radius: 50%;
        display: grid;
        place-items: center;
    }

    .bj-chip-stack {
        position: relative;
        width: 58px;
        height: 44px;
    }

    .bj-chip {
        position: absolute;
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        color: #fff;
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        font-weight: 800;
        border: 3px dashed rgba(255,255,255,0.55);
        box-shadow: 0 8px 18px rgba(0,0,0,0.42), inset 0 0 0 4px rgba(0,0,0,0.16);
    }

    .chip-red { left: 0; top: 2px; background: #97101c; }
    .chip-gold { left: 14px; top: -3px; background: #b38022; }
    .chip-black { left: 28px; top: 3px; background: #15181f; }

    .bj-hud {
        grid-area: hud;
        display: grid;
        gap: 12px;
        align-content: start;
    }

    .bj-bottom-strip {
        grid-area: bottom;
        display: grid;
        gap: 10px;
        align-items: start;
    }

    .bj-shortcuts {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
        padding: 8px;
        border: 1px solid var(--bj-border);
        background: rgba(7,8,10,0.78);
        box-shadow: var(--bj-shadow-panel);
    }

    .bj-shortcuts span {
        color: var(--bj-text-soft);
        font-size: 12px;
        font-weight: 700;
    }

    kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
        height: 24px;
        padding: 0 7px;
        border-radius: 5px;
        border: 1px solid rgba(255,255,255,0.18);
        background: linear-gradient(180deg, #1b2028, #0a0c10);
        color: #fff;
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .bj-study-panels {
        grid-area: study;
        display: grid;
        gap: 12px;
    }

    .bj-collapsible {
        border: 1px solid var(--bj-border);
        border-radius: var(--bj-radius-md);
        background:
            linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015)),
            var(--bj-panel);
        box-shadow: var(--bj-shadow-panel);
        overflow: hidden;
    }

    .bj-collapsible > summary {
        list-style: none;
        cursor: pointer;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        color: #fff;
        background: linear-gradient(90deg, rgba(196,18,34,0.22), rgba(255,255,255,0.02));
        border-bottom: 1px solid var(--bj-border);
        user-select: none;
    }

    .bj-collapsible > summary::after {
        content: "";
        width: 8px;
        height: 8px;
        border-right: 2px solid currentColor;
        border-bottom: 2px solid currentColor;
        transform: rotate(45deg);
        opacity: 0.7;
        transition: transform 160ms ease;
    }

    .bj-collapsible[open] > summary::after {
        transform: rotate(225deg);
    }

    .bj-collapsible > summary::-webkit-details-marker { display: none; }
    .bj-collapsible > summary::marker { content: ""; }
    .bj-collapsible-body { padding: 14px; }

    .bj-counts-panel,
    .bj-settings-panel {
        box-shadow: none;
    }

    .bj-counts-panel {
        max-width: 520px;
        justify-self: center;
        width: 100%;
    }

    .bj-control-panel {
        max-width: 980px;
        width: 100%;
        justify-self: center;
    }

    .bj-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .bj-rules-grid,
    .bj-target-grid {
        grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
    }

    .bj-grid label,
    .bj-speed-control,
    .bj-bet-compact {
        display: grid;
        gap: 6px;
        color: var(--bj-text-soft);
        font-size: 12px;
        font-weight: 700;
    }

    .bj-checks {
        display: grid;
        gap: 8px;
        margin: 8px 0 14px;
    }

    .bj-checks label,
    .bj-inline-check {
        min-height: 32px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--bj-text-soft);
        font-size: 12px;
        font-weight: 700;
    }

    .bj-nowrap { white-space: nowrap; }

    input,
    select {
        width: 100%;
        min-height: 40px;
        border-radius: var(--bj-radius-sm);
        border: 1px solid var(--bj-field-border);
        background: var(--bj-field-bg);
        color: var(--bj-text);
        padding: 8px 10px;
        font: 700 13px Inter, system-ui, sans-serif;
        outline: none;
        transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    input[type="checkbox"] {
        width: 18px;
        min-height: 18px;
        height: 18px;
        accent-color: var(--bj-accent-red);
    }

    input:focus,
    select:focus,
    button:focus-visible,
    a:focus-visible,
    summary:focus-visible {
        outline: 2px solid rgba(213,168,79,0.75);
        outline-offset: 2px;
    }

    .bj-btn {
        min-height: 44px;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: var(--bj-radius-md);
        padding: 11px 16px;
        color: #fff;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        background: linear-gradient(180deg, #252b35 0%, #11151b 100%);
        box-shadow: 0 12px 26px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.18);
        cursor: pointer;
        touch-action: manipulation;
        transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease, opacity 160ms ease;
    }

    .bj-btn:hover:not(:disabled):not(.disabled) {
        transform: translateY(-1px);
        filter: brightness(1.08);
        box-shadow: 0 16px 34px rgba(0,0,0,0.5), 0 0 26px rgba(220,31,53,0.2), inset 0 1px 0 rgba(255,255,255,0.24);
    }

    .bj-btn:active:not(:disabled):not(.disabled) {
        transform: translateY(1px);
    }

    .bj-btn.primary,
    .bj-deal-btn,
    .bj-action-hit {
        background: linear-gradient(180deg, #dc1f35 0%, #8d0b17 100%);
    }

    .bj-action-stand { background: linear-gradient(180deg, #3c4655 0%, #171c24 100%); }
    .bj-action-double { background: linear-gradient(180deg, #d8a23b 0%, #7b5416 100%); color: #160f05; text-shadow: 0 1px 0 rgba(255,255,255,0.18); }
    .bj-action-split { background: linear-gradient(180deg, #4f5fc5 0%, #22285f 100%); }
    .bj-action-surrender { background: linear-gradient(180deg, #9c2130 0%, #4c0d15 100%); }
    .bj-action-insurance { background: linear-gradient(180deg, #e1ad42 0%, #815b1d 100%); color: #180f03; }
    .bj-action-skip { background: linear-gradient(180deg, #252b35 0%, #11151b 100%); }

    .bj-btn:disabled,
    .bj-btn.disabled {
        background: var(--bj-disabled-bg);
        color: var(--bj-disabled-text);
        border-color: rgba(255,255,255,0.08);
        cursor: not-allowed;
        opacity: 0.72;
        box-shadow: none;
        filter: grayscale(0.35);
    }

    .bj-bet-row {
        display: grid;
        grid-template-columns: minmax(120px, 180px) minmax(130px, max-content);
        gap: 10px;
        align-items: end;
        margin-bottom: 12px;
    }

    .bj-bet-row .bj-inline-check {
        grid-column: 1 / -1;
    }

    .bj-action-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 9px;
    }

    .bj-mono,
    .bj-stats-grid strong,
    .bj-count-quiz-stats strong,
    .bj-speed-stats strong,
    .bj-log-time,
    .bj-speed-timer {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-variant-numeric: tabular-nums;
    }

    .bj-mono {
        color: var(--bj-text-soft);
        font-size: 12px;
        overflow-wrap: anywhere;
    }

    .bj-subheading {
        margin: 14px 0 8px;
        color: rgba(213,168,79,0.92);
    }

    .bj-hint-grid {
        display: grid;
        gap: 10px;
    }

    .bj-hint-card {
        min-height: 106px;
        display: grid;
        align-content: start;
        gap: 8px;
        padding: 12px;
        border-radius: var(--bj-radius-sm);
        border: 1px solid var(--bj-border);
        background: linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.012)), var(--bj-panel-2);
    }

    .bj-hint-card h4 {
        margin: 0;
        color: var(--bj-text-soft);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .bj-hint-card strong {
        color: #fff;
        font-family: Rajdhani, Inter, sans-serif;
        font-size: 28px;
        line-height: 1;
        text-transform: uppercase;
    }

    .bj-hint-card p {
        margin: 0;
        color: var(--bj-text-soft);
        font-size: 13px;
        line-height: 1.45;
    }

    .bj-hint-status,
    .bj-count-quiz-feedback,
    .bj-ready-status,
    .bj-act {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 11px;
        line-height: 1.25;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 4px 8px;
    }

    .bj-hint-status-neutral,
    .bj-count-quiz-feedback-neutral {
        background: #252d38;
        border-color: #465363;
        color: #d5dce7;
    }

    .bj-hint-status-correct,
    .bj-count-quiz-feedback-correct {
        background: rgba(24,181,107,0.16);
        border-color: rgba(24,181,107,0.72);
        color: #d7ffe8;
        box-shadow: 0 0 18px rgba(24,181,107,0.16);
    }

    .bj-hint-status-wrong,
    .bj-count-quiz-feedback-wrong {
        background: rgba(228,63,79,0.18);
        border-color: rgba(228,63,79,0.76);
        color: #ffe1e5;
        box-shadow: 0 0 18px rgba(228,63,79,0.18);
    }

    .bj-stats-grid,
    .bj-count-quiz-stats,
    .bj-speed-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .bj-stats-grid div,
    .bj-count-quiz-stats div,
    .bj-speed-stats div {
        min-width: 0;
        padding: 10px;
        border-radius: var(--bj-radius-sm);
        background: var(--bj-panel-2);
        border: 1px solid var(--bj-border);
    }

    .bj-stats-grid strong,
    .bj-count-quiz-stats strong,
    .bj-speed-stats strong {
        display: block;
        margin-top: 5px;
        color: #fff;
        font-size: 16px;
        overflow-wrap: anywhere;
    }

    .bj-mistakes,
    #bj-history-list {
        margin: 8px 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 7px;
    }

    .bj-mistakes li,
    .bj-history-item,
    .bj-log-item {
        padding: 9px 10px;
        border-radius: var(--bj-radius-sm);
        background: var(--bj-panel-2);
        border: 1px solid var(--bj-border);
        color: var(--bj-text-soft);
        font-size: 12px;
        line-height: 1.35;
    }

    #bj-log-list {
        display: grid;
        gap: 7px;
        max-height: 210px;
        overflow: auto;
    }

    .bj-log-time {
        margin-right: 8px;
        color: var(--bj-gold);
        font-size: 11px;
    }

    .bj-guide p,
    .bj-chart-note {
        margin: 0 0 10px;
        color: var(--bj-text-soft);
        font-size: 13px;
        line-height: 1.5;
    }

    .bj-guide h4,
    .bj-chart-wrap h4 {
        margin: 12px 0 8px;
        color: #fff;
        font-family: Rajdhani, Inter, sans-serif;
        font-size: 18px;
        text-transform: uppercase;
    }

    .bj-guide ul {
        margin: 0;
        padding-left: 18px;
        color: var(--bj-text-soft);
        font-size: 13px;
        line-height: 1.5;
    }

    .bj-legend {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 7px 10px;
        margin-bottom: 12px;
        align-items: center;
        color: var(--bj-text-soft);
        font-size: 12px;
    }

    .bj-chart-grid {
        display: grid;
        gap: 12px;
    }

    .bj-chart-wrap {
        min-width: 0;
        overflow-x: auto;
        padding: 12px;
        border-radius: var(--bj-radius-md);
        background: var(--bj-panel-2);
        border: 1px solid var(--bj-border);
    }

    .bj-chart {
        width: 100%;
        min-width: 360px;
        border-collapse: collapse;
        color: var(--bj-text-soft);
        font-size: 12px;
    }

    .bj-chart th,
    .bj-chart td {
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 8px;
        text-align: left;
    }

    .bj-chart th {
        position: sticky;
        top: 0;
        color: #fff;
        background: #0c0f14;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .bj-act { min-width: 34px; padding: 4px 8px; }
    .bj-act-hit { background: rgba(196,18,34,0.28); border-color: rgba(196,18,34,0.8); color: #ffdfe3; }
    .bj-act-stand { background: rgba(77,89,108,0.32); border-color: rgba(121,136,160,0.8); color: #eef3fb; }
    .bj-act-double { background: rgba(213,168,79,0.28); border-color: rgba(213,168,79,0.8); color: #ffe7b0; }
    .bj-act-dh { background: rgba(230,169,58,0.22); border-color: rgba(230,169,58,0.7); color: #ffe5ad; }
    .bj-act-ds { background: rgba(24,181,107,0.18); border-color: rgba(24,181,107,0.7); color: #dcffe9; }
    .bj-act-split { background: rgba(89,95,201,0.3); border-color: rgba(127,134,237,0.78); color: #e8e8ff; }

    .bj-speed-row {
        display: grid;
        gap: 10px;
        margin-bottom: 12px;
    }

    .bj-speed-controls,
    .bj-speed-actions,
    .bj-count-quiz-actions,
    .bj-count-quiz-answer-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: end;
    }

    .bj-speed-control select {
        min-width: min(260px, 100%);
    }

    .bj-speed-timer {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 108px;
        padding: 8px 12px;
        border-radius: 999px;
        background: #090b0f;
        border: 1px solid var(--bj-border);
        color: #fff;
        font-weight: 800;
    }

    .bj-speed-current {
        display: grid;
        gap: 8px;
        margin-bottom: 10px;
    }

    .bj-speed-current-label {
        color: var(--bj-text-soft);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 800;
    }

    .bj-speed-last-card {
        min-height: 88px;
        width: fit-content;
        min-width: 94px;
        max-width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: var(--bj-radius-md);
        background: var(--bj-card-bg);
        color: var(--bj-card-text);
        border: 1px solid var(--bj-card-border);
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(1.4rem, 5vw, 2.4rem);
        font-weight: 800;
        box-shadow: 0 12px 28px rgba(0,0,0,0.34);
        overflow-wrap: anywhere;
    }

    .bj-count-quiz-answer-row .bj-btn,
    .bj-speed-actions .bj-btn {
        min-width: 82px;
    }

    .bj-count-quiz-answer-row .bj-btn {
        min-height: 58px;
        font-size: 22px;
    }

    .bj-speed-stream {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        min-height: 32px;
        margin-top: 8px;
