@page "/bj"
@model Ivone.dev.Pages.BjModel
@{
    ViewData["Title"] = "Blackjack Trainer";
}

<div class="bj-layout">
    <header class="bj-topbar" aria-label="Blackjack trainer status">
        <div class="bj-brand">
            <span class="bj-brand-mark" aria-hidden="true"></span>
            <div>
                <span class="bj-kicker">Ivone.dev Casino Lab</span>
                <h1>Blackjack Command</h1>
            </div>
        </div>

        <div class="bj-topbar-center">
            <div class="bj-mode-chip">
                <span>Mode</span>
                <strong>Basic Strategy Drill</strong>
            </div>
            <div class="bj-mode-chip bj-mode-chip-rules">
                <span>Ruleset</span>
                <strong>6 Decks / H17 / DAS / 3:2</strong>
            </div>
        </div>

        <div class="bj-topbar-metrics">
            <div class="bj-top-metric"><span>Bankroll</span><strong id="bj-bankroll-now">&euro;0</strong></div>
            <div class="bj-top-metric"><span>Running</span><strong id="bj-running-count">-</strong></div>
            <div class="bj-top-metric"><span>True</span><strong id="bj-true-count">-</strong></div>
            <div class="bj-top-metric"><span>Shoe</span><strong id="bj-shoe-depth">-</strong></div>
        </div>
    </header>

    <aside class="bj-sidebar" aria-label="Training navigation">
        <div class="bj-sidebar-head">
            <span class="bj-kicker">Training Lobby</span>
            <strong>Drill Select</strong>
        </div>

        <nav class="bj-nav-list" aria-label="Blackjack drills">
            <a class="bj-nav-item active" href="#bj-panel-controls"><span class="bj-nav-icon cards"></span><span>Table Drill</span><em>Live</em></a>
            <a class="bj-nav-item" href="#bj-panel-basic"><span class="bj-nav-icon chart"></span><span>Basic Strategy</span><em>82%</em></a>
            <a class="bj-nav-item" href="#bj-panel-count-quiz"><span class="bj-nav-icon target"></span><span>Running Count</span><em>L3</em></a>
            <a class="bj-nav-item" href="#bj-panel-speed-count"><span class="bj-nav-icon speed"></span><span>True Count</span><em>Fast</em></a>
            <a class="bj-nav-item" href="#bj-panel-perfect"><span class="bj-nav-icon deviation"></span><span>Deviations</span><em>Index</em></a>
            <a class="bj-nav-item" href="#bj-panel-history"><span class="bj-nav-icon replay"></span><span>Mistake Bank</span><em>Review</em></a>
            <a class="bj-nav-item" href="#bj-panel-rules"><span class="bj-nav-icon rules"></span><span>Rulesets</span><em>6D</em></a>
            <a class="bj-nav-item" href="#bj-panel-settings"><span class="bj-nav-icon settings"></span><span>Settings</span><em>HUD</em></a>
        </nav>

        <details id="bj-panel-settings" class="bj-collapsible bj-settings-panel" open>
            <summary>Table Settings</summary>
            <div class="bj-collapsible-body">
                <h3 class="bj-subheading">Training Aids</h3>
                <div class="bj-checks">
                    <label><input id="bj-h17" type="checkbox" checked /> Dealer hits soft 17</label>
                    <label><input id="bj-das" type="checkbox" checked /> Double after split</label>
                    <label><input id="bj-rsa" type="checkbox" /> Resplit aces</label>
                    <label><input id="bj-insurance" type="checkbox" checked /> Insurance available</label>
                    <label><input id="bj-show-rc" type="checkbox" checked /> Allow running count display</label>
                    <label><input id="bj-show-tc" type="checkbox" checked /> Allow true count display</label>
                    <label><input id="bj-show-depth" type="checkbox" checked /> Allow shoe depth display</label>
                    <label><input id="bj-show-hints" type="checkbox" checked /> Allow strategy hints</label>
                </div>

                <h3 class="bj-subheading">Display</h3>
                <div class="bj-grid">
                    <label>Color Theme
                        <select id="bj-theme">
                            <option value="dark">Dark</option>
                            <option value="light">Light</option>
                        </select>
                    </label>
                </div>

                <button id="bj-start-session" class="bj-btn primary" type="button">Start New Session</button>
                <p id="bj-session-label" class="bj-mono">Session: -</p>
            </div>
        </details>
    </aside>

    <main class="bj-stage" aria-label="Blackjack training table">
        <section class="bj-table">
            <details id="bj-panel-counts" class="bj-collapsible bj-counts-panel" open>
                <summary>Live Count Shield</summary>
                <div class="bj-collapsible-body">
                    <label class="bj-inline-check">
                        <input id="bj-mask-counts" type="checkbox" />
                        Hide live running and true counts while I play
                    </label>
                </div>
            </details>

            <div class="bj-game-focus">
                <div class="bj-table-rail" aria-hidden="true"></div>
                <div class="bj-table-felt">
                    <div class="bj-felt-noise" aria-hidden="true"></div>
                    <span class="bj-table-rule bj-table-rule-top">Blackjack pays 3 to 2</span>
                    <span class="bj-table-rule bj-table-rule-left">Insurance pays 2 to 1</span>
                    <span class="bj-table-rule bj-table-rule-bottom">Dealer stands on soft 17</span>

                    <div class="bj-dealer-zone">
                        <div class="bj-dealer-plate">
                            <span>Dealer</span>
                            <strong id="bj-dealer-total">-</strong>
                        </div>
                        <div id="bj-dealer-cards" class="bj-cards" aria-label="Dealer cards"></div>
                    </div>

                    <div class="bj-tray bj-shoe-tray" aria-hidden="true">
                        <span>Shoe</span>
                        <i></i><i></i><i></i>
                    </div>
                    <div class="bj-tray bj-discard-tray" aria-hidden="true">
                        <span>Discard</span>
                        <i></i><i></i>
                    </div>

                    <div class="bj-center-mark" aria-hidden="true">
                        <span>Decision Window</span>
                    </div>

                    <div class="bj-bet-circle" aria-hidden="true">
                        <div class="bj-chip-stack">
                            <span class="bj-chip chip-red">25</span>
                            <span class="bj-chip chip-gold">100</span>
                            <span class="bj-chip chip-black">500</span>
                        </div>
                    </div>

                    <div class="bj-player-zone">
                        <div class="bj-player-heading">
                            <span>Player Hands</span>
                            <strong id="bj-lobby-label" class="bj-lobby-neutral">Lobby</strong>
                        </div>
                        <div id="bj-player-hands" class="bj-hand-stack" aria-label="Player hands"></div>
                    </div>
                </div>
            </div>

            <details id="bj-panel-controls" class="bj-collapsible bj-control-panel" open>
                <summary>Action Console</summary>
                <div class="bj-collapsible-body">
                    <div class="bj-bet-row">
                        <label class="bj-bet-compact">
                            <span id="bj-bet-label">Bet (&euro; | Bank &euro;0)</span>
                            <input id="bj-bet-units" type="number" min="1" value="1" />
                        </label>
                        <button id="bj-deal" class="bj-btn bj-deal-btn" type="button">Deal Hand</button>
                        <label class="bj-inline-check bj-nowrap">
                            <input id="bj-auto-deal" type="checkbox" checked />
                            Auto next hand
                        </label>
                    </div>

                    <div class="bj-action-row" id="bj-actions" aria-label="Blackjack actions">
                        <button type="button" class="bj-btn bj-action-btn bj-action-hit" data-action="Hit">Hit</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-stand" data-action="Stand">Stand</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-double" data-action="Double">Double</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-split" data-action="Split">Split</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-surrender" data-action="Surrender">Surrender</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-insurance" data-action="InsuranceTake">Insurance</button>
                        <button type="button" class="bj-btn bj-action-btn bj-action-skip" data-action="InsuranceSkip">No Insurance</button>
                    </div>
                </div>
            </details>
        </section>
    </main>

    <aside class="bj-hud" aria-label="Training intelligence">
        <details id="bj-panel-strategy" class="bj-collapsible bj-hud-panel" open>
            <summary>Current Hand</summary>
            <div class="bj-collapsible-body bj-hint">
                <div class="bj-hint-grid">
                    <section class="bj-hint-card">
                        <h4>Your Action</h4>
                        <strong id="bj-hint-player-action">-</strong>
                        <span id="bj-hint-status" class="bj-hint-status bj-hint-status-neutral">Waiting</span>
                    </section>
                    <section class="bj-hint-card">
                        <h4>Optimal Action</h4>
                        <strong id="bj-hint-optimal-action">-</strong>
                        <p id="bj-hint-text">-</p>
                    </section>
                </div>
            </div>
        </details>

        <details id="bj-panel-stats" class="bj-collapsible bj-hud-panel" open>
            <summary>Session HUD</summary>
            <div class="bj-collapsible-body bj-stats">
                <div class="bj-stats-grid">
                    <div><span>Rounds</span><strong id="bj-stat-rounds">0</strong></div>
                    <div><span>Hands</span><strong id="bj-stat-hands">0</strong></div>
                    <div><span>Basic</span><strong id="bj-stat-basic">0</strong></div>
                    <div><span>Deviation</span><strong id="bj-stat-deviation">0</strong></div>
                    <div><span>Bet</span><strong id="bj-stat-bet">0</strong></div>
                    <div><span>RC</span><strong id="bj-stat-rc">0</strong></div>
                    <div><span>TC</span><strong id="bj-stat-tc">0</strong></div>
                    <div><span>EV Leak</span><strong id="bj-stat-ev">&euro;0</strong></div>
                </div>
                <h3 class="bj-subheading">Mistake Breakdown</h3>
                <ul id="bj-mistakes" class="bj-mistakes"></ul>
            </div>
        </details>

        <details id="bj-panel-history" class="bj-collapsible bj-hud-panel" open>
            <summary>Recent Hands</summary>
            <div class="bj-collapsible-body bj-history">
                <div id="bj-history-list"></div>
            </div>
        </details>
    </aside>

    <section class="bj-bottom-strip" aria-label="Keyboard shortcuts and activity">
        <div class="bj-shortcuts">
            <span><kbd>H</kbd> Hit</span>
            <span><kbd>S</kbd> Stand</span>
            <span><kbd>D</kbd> Double</span>
            <span><kbd>P</kbd> Split</span>
            <span><kbd>Space</kbd> Next</span>
        </div>
        <details id="bj-panel-log" class="bj-collapsible bj-log-panel" open>
            <summary>Table Feed</summary>
            <div class="bj-collapsible-body">
                <div id="bj-log-list"></div>
            </div>
        </details>
    </section>

    <section class="bj-study-panels" aria-label="Study panels">
        <details id="bj-panel-rules" class="bj-collapsible bj-rules-bottom" open>
            <summary>Ruleset Setup</summary>
            <div class="bj-collapsible-body">
                <div class="bj-grid bj-rules-grid">
                    <label>Mode
                        <select id="bj-mode">
                            <option value="Guided">Guided</option>
                            <option value="FreePlay">Free Play</option>
                            <option value="CountingOnly">Counting Only</option>
                            <option value="DeviationsOnly">Deviations Only</option>
                            <option value="BetSizingOnly">Bet Sizing Only</option>
                            <option value="Exam">Exam</option>
                        </select>
                    </label>
                    <label>Decks
                        <select id="bj-decks">
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="4">4</option>
                            <option value="6" selected>6</option>
                            <option value="8">8</option>
                        </select>
                    </label>
                    <label>Penetration %
                        <input id="bj-penetration" type="number" min="55" max="90" value="75" />
                    </label>
                    <label>Burn Cards
                        <input id="bj-burn" type="number" min="0" max="16" value="1" />
                    </label>
                    <label>Spread Max
                        <input id="bj-spread" type="number" min="2" max="20" value="8" />
                    </label>
                    <label>Bankroll (&euro;)
                        <input id="bj-bankroll" type="number" min="10" value="200" />
                    </label>
                    <label>Max Splits
                        <input id="bj-max-splits" type="number" min="1" max="4" value="3" />
                    </label>
                    <label>Double Rule
                        <select id="bj-double-rule">
                            <option value="AnyTwo">Any Two</option>
                            <option value="NineToEleven">9-11</option>
                            <option value="TenToEleven">10-11</option>
                        </select>
                    </label>
                    <label>Blackjack Payout
                        <select id="bj-payout">
                            <option value="ThreeToTwo">3:2</option>
                            <option value="SixToFive">6:5</option>
                        </select>
                    </label>
                </div>
            </div>
        </details>

        <details id="bj-panel-guide" class="bj-collapsible bj-guide-bottom" open>
            <summary>Quick Guide</summary>
            <div class="bj-collapsible-body">
                <div class="bj-guide">
                    <p>Fast practical rules for live play and count training.</p>
                    <h4>Basic Strategy</h4>
                    <ul>
                        <li>Hard totals: stand on 17+, hit 8 or less.</li>
                        <li>Hard 13-16: stand vs dealer 2-6, hit vs 7-A.</li>
                        <li>Hard 12: stand vs 4-6, hit vs 2-3 or 7-A.</li>
                        <li>Double 11 vs most upcards; 10 vs 2-9; 9 vs 3-6.</li>
                        <li>Soft hands: A,8 usually stands; A,7 doubles vs 3-6 if allowed.</li>
                        <li>Pairs: split A,A and 8,8; never split 10,10 or 5,5.</li>
                        <li>Insurance is generally a bad base-strategy play unless the count is strong.</li>
                    </ul>
                    <h4>Hi-Lo Counting</h4>
                    <ul>
                        <li>2-6 = +1, 7-9 = 0, 10-A = -1.</li>
                        <li>Running Count: update on every exposed card.</li>
                        <li>True Count: running count divided by decks remaining.</li>
                        <li>Higher true counts support larger bets and selected index deviations.</li>
                    </ul>
                </div>
            </div>
        </details>

        <details id="bj-panel-basic" class="bj-collapsible bj-basic-bottom" open>
            <summary>Basic Strategy Chart</summary>
            <div class="bj-collapsible-body">
                <p class="bj-chart-note">Baseline chart for trainer defaults: multi-deck, H17, DAS on, no surrender, double any two.</p>

                <div class="bj-legend">
                    <span class="bj-act bj-act-hit">H</span><span>Hit</span>
                    <span class="bj-act bj-act-stand">S</span><span>Stand</span>
                    <span class="bj-act bj-act-double">D</span><span>Double</span>
                    <span class="bj-act bj-act-dh">D/H</span><span>Double else hit</span>
                    <span class="bj-act bj-act-ds">D/S</span><span>Double else stand</span>
                    <span class="bj-act bj-act-split">SP</span><span>Split</span>
                </div>

                <div class="bj-chart-grid">
                    <div class="bj-chart-wrap">
                        <h4>Hard Totals</h4>
                        <table class="bj-chart">
                            <thead><tr><th>Player</th><th>Dealer Upcard</th><th>Play</th></tr></thead>
                            <tbody>
                                <tr><td>8 or less</td><td>Any</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>9</td><td>3-6</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>9</td><td>2, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>10</td><td>2-9</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>10</td><td>10, A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>11</td><td>2-A</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>12</td><td>4-6</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>12</td><td>2-3, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>13-16</td><td>2-6</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>13-16</td><td>7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>17+</td><td>Any</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="bj-chart-wrap">
                        <h4>Soft Totals</h4>
                        <table class="bj-chart">
                            <thead><tr><th>Player</th><th>Dealer Upcard</th><th>Play</th></tr></thead>
                            <tbody>
                                <tr><td>A,2 / A,3</td><td>5-6</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>A,2 / A,3</td><td>2-4, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>A,4 / A,5</td><td>4-6</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>A,4 / A,5</td><td>2-3, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>A,6</td><td>3-6</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>A,6</td><td>2, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>A,7</td><td>3-6</td><td><span class="bj-act bj-act-ds">D/S</span></td></tr>
                                <tr><td>A,7</td><td>2, 7, 8</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>A,7</td><td>9, 10, A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>A,8</td><td>6 (H17)</td><td><span class="bj-act bj-act-ds">D/S</span></td></tr>
                                <tr><td>A,8</td><td>Other upcards</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>A,9</td><td>Any</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="bj-chart-wrap">
                        <h4>Pairs</h4>
                        <table class="bj-chart">
                            <thead><tr><th>Pair</th><th>Dealer Upcard</th><th>Play</th></tr></thead>
                            <tbody>
                                <tr><td>A,A</td><td>Any</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>10,10</td><td>Any</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>9,9</td><td>2-6, 8-9</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>9,9</td><td>7, 10, A</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>8,8</td><td>Any</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>7,7</td><td>2-7</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>7,7</td><td>8-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>6,6</td><td>3-6</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>6,6</td><td>2, 7-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>5,5</td><td>2-9</td><td><span class="bj-act bj-act-dh">D/H</span></td></tr>
                                <tr><td>5,5</td><td>10, A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>4,4 (DAS)</td><td>5-6</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>4,4 (DAS)</td><td>Other upcards</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                                <tr><td>3,3 / 2,2 (DAS)</td><td>2-7</td><td><span class="bj-act bj-act-split">SP</span></td></tr>
                                <tr><td>3,3 / 2,2 (DAS)</td><td>8-A</td><td><span class="bj-act bj-act-hit">H</span></td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </details>

        <details id="bj-panel-perfect" class="bj-collapsible bj-perfect-bottom" open>
            <summary>Perfect Strategy Layer</summary>
            <div class="bj-collapsible-body">
                <p class="bj-chart-note">Execution order: basic chart first, then true-count deviations, then bet ramp.</p>
                <div class="bj-chart-grid">
                    <div class="bj-chart-wrap">
                        <h4>Bet Sizing Ramp</h4>
                        <table class="bj-chart">
                            <thead><tr><th>True Count Floor</th><th>Bet Size</th></tr></thead>
                            <tbody>
                                <tr><td>TC &lt;= 0</td><td><span class="bj-act bj-act-stand">1x base</span></td></tr>
                                <tr><td>TC = +1</td><td><span class="bj-act bj-act-double">2x base</span></td></tr>
                                <tr><td>TC = +2</td><td><span class="bj-act bj-act-double">4x base</span></td></tr>
                                <tr><td>TC = +3</td><td><span class="bj-act bj-act-double">6x base</span></td></tr>
                                <tr><td>TC &gt;= +4</td><td><span class="bj-act bj-act-split">Max spread</span></td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="bj-chart-wrap">
                        <h4>Hi-Lo Deviations</h4>
                        <table class="bj-chart">
                            <thead><tr><th>Situation</th><th>At / Above TC</th><th>Deviation</th></tr></thead>
                            <tbody>
                                <tr><td>Insurance vs A</td><td>+3</td><td><span class="bj-act bj-act-split">Take</span></td></tr>
                                <tr><td>16 vs 10</td><td>0</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>15 vs 10</td><td>+4</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>12 vs 3</td><td>+2</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>12 vs 2</td><td>+3</td><td><span class="bj-act bj-act-stand">S</span></td></tr>
                                <tr><td>10 vs 10</td><td>+4</td><td><span class="bj-act bj-act-double">D</span></td></tr>
                                <tr><td>10 vs A</td><td>+4</td><td><span class="bj-act bj-act-double">D</span></td></tr>
                                <tr><td>9 vs 2</td><td>+1</td><td><span class="bj-act bj-act-double">D</span></td></tr>
                                <tr><td>9 vs 7</td><td>+3</td><td><span class="bj-act bj-act-double">D</span></td></tr>
                                <tr><td>11 vs A</td><td>+1</td><td><span class="bj-act bj-act-double">D</span></td></tr>
