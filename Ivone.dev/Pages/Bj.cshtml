                    <div><span>Remaining</span><strong id="bj-count-remaining">-</strong></div>
                    <div><span>Last Run</span><strong id="bj-count-one-deck-time">-</strong></div>
                    <div><span>Best</span><strong id="bj-count-best-time">-</strong></div>
