                <div id="bj-count-stream" class="bj-speed-stream"></div>

                <h3 class="bj-subheading">Count Sign Drill Targets (seconds)</h3>
                <div class="bj-grid bj-target-grid">
                    <label>L1 acceptable <input id="bj-count-quiz-target-l1" type="number" min="0.1" step="0.1" value="4.0" /></label>
                    <label>L2 acceptable <input id="bj-count-quiz-target-l2" type="number" min="0.1" step="0.1" value="7.0" /></label>
